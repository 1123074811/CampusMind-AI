MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=campusmind
MYSQL_USERNAME=campusmind
MYSQL_ROOT_PASSWORD=<set-in-.env>
MYSQL_PASSWORD=<set-in-.env>
MYSQL_IMAGE=docker.1ms.run/mysql:8.4

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
IMPORT_REDIS_PASSWORD=

MONGODB_URI=mongodb://localhost:27017/campusmind
IMPORT_MONGO_URI=mongodb://localhost:27017/campusmind

PGVECTOR_HOST=localhost
PGVECTOR_PORT=5432
PGVECTOR_DATABASE=campusmind_vector
PGVECTOR_USERNAME=campusmind
PGVECTOR_PASSWORD=<set-in-.env>

AUTH_JWT_ISSUER=campusmind-auth
AUTH_JWT_SECRET=<set-at-least-32-bytes>

OPENAI_API_KEY=
OPENAI_BASE_URL=
SPRING_AI_CHAT_MODEL=none
SPRING_AI_EMBEDDING_MODEL=none
CAMPUS_AI_MODE=rule
# 可选：预下载 ONNX 模型时填写 file: URI；留空则 llm,pg 首次启动从固定版本地址下载。
# TRANSFORMER_MODEL_URI=file:/path/to/paraphrase-multilingual-MiniLM-L12-v2.onnx
# TRANSFORMER_TOKENIZER_URI=file:/path/to/tokenizer.json
# TRANSFORMER_CACHE_DIR=/path/to/persistent/model-cache
