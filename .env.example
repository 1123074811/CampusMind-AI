MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DOCKER_PORT=13306
MYSQL_DATABASE=campusmind
MYSQL_USERNAME=campusmind
MYSQL_ROOT_PASSWORD=<set-in-.env>
MYSQL_PASSWORD=<set-in-.env>
MYSQL_IMAGE=mysql:8.4

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DOCKER_PORT=16379
REDIS_PASSWORD=
IMPORT_REDIS_PASSWORD=

MONGODB_URI=mongodb://localhost:27017/campusmind
MONGO_DOCKER_PORT=27018
IMPORT_MONGO_URI=mongodb://localhost:27017/campusmind

PGVECTOR_HOST=localhost
PGVECTOR_PORT=5432
PGVECTOR_DOCKER_PORT=15432
PGVECTOR_DATABASE=campusmind_vector
PGVECTOR_USERNAME=campusmind
PGVECTOR_PASSWORD=<set-in-.env>

AUTH_JWT_ISSUER=campusmind-auth
AUTH_JWT_SECRET=<set-at-least-32-bytes>
AUTH_JWT_ACCESS_TTL_MINUTES=15
AUTH_JWT_REFRESH_TTL_DAYS=30
AUTH_REDIS_HOST=localhost
AUTH_COOKIE_SECURE=false
AUTH_MAIL_ENABLED=false
AUTH_MAIL_HOST=localhost
AUTH_MAIL_PORT=25
AUTH_MAIL_USERNAME=
AUTH_MAIL_PASSWORD=
AUTH_MAIL_FROM=no-reply@campusmind.local
AUTH_RESET_URL=http://localhost:5173/reset-password
AUTH_RESET_TOKEN_TTL_MINUTES=30
# 仅本地开发可设为 true；生产必须保持 false，避免找回令牌出现在接口响应中。
AUTH_DEV_EXPOSE_RESET_TOKEN=false
CRAWLER_REDIS_HOST=localhost
USER_REDIS_HOST=localhost
AI_REDIS_HOST=localhost
CAMPUS_AI_SHORT_TERM_MEMORY_TTL=PT24H
PRIVACY_POLICY_VERSION=2026-07-14
PRIVACY_RETENTION_DAYS=365

# 可选：推送供应商适配器的标准 Webhook 地址；为空时仍保留站内通知与投递记录。
FEED_PUSH_WEBHOOK_URL=

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=
SPRING_AI_CHAT_MODEL=none
SPRING_AI_EMBEDDING_MODEL=none
CAMPUS_AI_MODE=rule
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
CAMPUS_AI_WEB_SEARCH_ENABLED=true
CAMPUS_AI_WEB_SEARCH_MAX_RESULTS=5

# Android release signing (CI/发布机环境变量，不要提交 keystore)
CAMPUSMIND_KEYSTORE_PATH=
CAMPUSMIND_KEYSTORE_PASSWORD=
CAMPUSMIND_KEY_ALIAS=
CAMPUSMIND_KEY_PASSWORD=

# 可选：校方 OIDC，启用 auth 服务的 sso profile 后必填
CAMPUS_OIDC_ISSUER_URI=
CAMPUS_OIDC_CLIENT_ID=
CAMPUS_OIDC_CLIENT_SECRET=
CAMPUS_OIDC_APP_CALLBACK_URL=
# 可选：预下载 ONNX 模型时填写 file: URI；留空则 llm,pg 首次启动从固定版本地址下载。
# TRANSFORMER_MODEL_URI=file:/path/to/paraphrase-multilingual-MiniLM-L12-v2.onnx
# TRANSFORMER_TOKENIZER_URI=file:/path/to/tokenizer.json
# TRANSFORMER_CACHE_DIR=/path/to/persistent/model-cache
